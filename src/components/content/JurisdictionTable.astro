---
import rules from '@/data/legal/bill-of-sale-state-rules.json';
import { ALL_JURISDICTIONS } from '@/data/jurisdictions';

interface Rule {
  notary_required: boolean | null;
  witness_required: boolean | null;
  governing_statute: string | null;
  statute_url: string | null;
  last_verified: string;
}

const rows = ALL_JURISDICTIONS.map((j) => ({
  region: j.region,
  country: j.country.toUpperCase(),
  slug: j.slug,
  rule: rules[j.code as keyof typeof rules] as Rule | undefined
}));
---
<div class="jt-wrap">
<table class="jt">
  <caption class="sr-only">Bill of sale requirements by US state and UK nation</caption>
  <thead>
    <tr>
      <th scope="col">Jurisdiction</th>
      <th scope="col">Notary</th>
      <th scope="col">Witnesses</th>
      <th scope="col">Governing law</th>
      <th scope="col">Verified</th>
    </tr>
  </thead>
  <tbody>
    {rows.map((r) => (
      <tr>
        <th scope="row"><a href={`/bill-of-sale/${r.slug}/`}>{r.region}</a> <span class="jt-country">({r.country})</span></th>
        <td data-label="Notary">{r.rule?.notary_required === true ? 'Required' : r.rule?.notary_required === false ? 'Not required' : '—'}</td>
        <td data-label="Witnesses">{r.rule?.witness_required === true ? 'Required' : r.rule?.witness_required === false ? 'Not required' : '—'}</td>
        <td data-label="Governing law">{r.rule?.statute_url ? <a href={r.rule.statute_url} rel="noopener">{r.rule.governing_statute}</a> : (r.rule?.governing_statute ?? '—')}</td>
        <td data-label="Verified"><time datetime={r.rule?.last_verified ?? ''}>{r.rule?.last_verified ?? '—'}</time></td>
      </tr>
    ))}
  </tbody>
</table>
</div>

<style>
.jt-wrap {
  margin: var(--sp-6) 0;
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
}
.jt { border-collapse: collapse; width: 100%; font-size: var(--fs-sm); }
.jt th, .jt td {
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border);
  text-align: left;
  vertical-align: top;
}
.jt thead th {
  background: var(--surface-2);
  font-weight: var(--fw-semibold);
  color: var(--fg);
  white-space: nowrap;
}
.jt tbody th { font-weight: var(--fw-medium); color: var(--fg); }
.jt tbody tr:last-child th,
.jt tbody tr:last-child td { border-bottom: 0; }
.jt tbody tr:hover { background: color-mix(in srgb, var(--accent-tint) 50%, transparent); }
.jt a { color: var(--link); }
.jt a:hover { color: var(--link-hover); }
.jt-country { color: var(--fg-subtle); font-weight: var(--fw-normal); }
.jt time { font-variant-numeric: tabular-nums; color: var(--fg-muted); }

/* Mobile: each row becomes a stacked card; each cell shows its column label.
   Caption + scope semantics are preserved for screen readers. */
@media (max-width: 767px) {
  .jt-wrap { border: 0; border-radius: 0; overflow: visible; }
  .jt thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
  .jt, .jt tbody, .jt tr, .jt th, .jt td { display: block; width: 100%; }
  .jt tr {
    border: 1px solid var(--border); border-radius: var(--r-md);
    padding: var(--sp-3) var(--sp-4); margin-bottom: var(--sp-3);
    background: var(--bg-elev);
  }
  .jt tr:hover { background: var(--bg-elev); }
  .jt tbody th {
    font-size: var(--fs-base); padding: 0 0 var(--sp-2); border: 0;
    margin-bottom: var(--sp-2); border-bottom: 1px solid var(--border);
  }
  .jt td {
    display: flex; justify-content: space-between; gap: var(--sp-4);
    padding: var(--sp-1) 0; border: 0; text-align: right;
  }
  .jt td::before {
    content: attr(data-label); font-weight: var(--fw-semibold);
    color: var(--fg-muted); text-align: left;
  }
}
</style>
