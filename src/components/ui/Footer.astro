---
import { NODE_SLUGS, NODE_LABELS, site, author } from '@/lib/site';
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="wordmark-foot" aria-label="Template.how home">
        <strong>Template</strong><span class="dot">.</span><span class="tld">how</span>
      </a>
      <p class="tagline">{site.tagline}</p>
      <p class="credit">Edited by <a href={author.url}>{author.name}</a>.</p>
    </div>
    <nav aria-label="Categories" class="footer-col">
      <p class="foot-nav-label">Categories</p>
      <ul>
        {NODE_SLUGS.map((slug) => (
          <li><a href={`/${slug}/`}>{NODE_LABELS[slug]}</a></li>
        ))}
      </ul>
    </nav>
    <nav aria-label="Site" class="footer-col">
      <p class="foot-nav-label">Site</p>
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
    </nav>
  </div>
  <div class="container sub">
    <small>&copy; {new Date().getFullYear()} Template.how. Nothing on this site is legal, tax, or financial advice.</small>
  </div>
</footer>

<style>
.site-footer {
  margin-top: var(--space-section);
  padding: var(--space-section-sm) 0 var(--sp-8);
  background: var(--bg-elev);
  border-top: 1px solid var(--border);
}
.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--sp-10) var(--sp-8);
}
@media (min-width: 640px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}
@media (min-width: 768px) {
  .footer-grid { grid-template-columns: 2fr 1fr 1fr; }
}
.footer-brand { max-width: 40ch; }
.foot-nav-label {
  font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: var(--tracking-wide);
  font-family: var(--font-body); font-weight: var(--fw-semibold);
  color: var(--fg-muted); margin: 0 0 var(--sp-3);
}
.footer-col ul { list-style: none; padding: 0; margin: 0; }
.footer-col li { margin-bottom: var(--sp-1); font-size: var(--fs-sm); }
.footer-col a {
  display: inline-flex; align-items: center; min-height: 36px;
  color: var(--link); text-decoration: none;
  transition: var(--transition-colors);
}
.footer-col a:hover { color: var(--accent); }
.footer-col a:focus-visible { outline: var(--ring); outline-offset: 2px; border-radius: var(--r-xs); }

.wordmark-foot {
  display: inline-block;
  font-family: var(--font-display); font-size: var(--fs-xl);
  margin: 0; color: var(--fg); text-decoration: none; letter-spacing: -0.02em;
}
.wordmark-foot:focus-visible { outline: var(--ring); outline-offset: 4px; border-radius: var(--r-xs); }
.wordmark-foot .dot { color: var(--accent); }
.wordmark-foot .tld { color: var(--fg-muted); font-weight: 400; }
.tagline { font-size: var(--fs-sm); color: var(--fg-muted); margin: var(--sp-3) 0 0; line-height: var(--lh-snug); }
.credit { font-size: var(--fs-sm); color: var(--fg-muted); margin: var(--sp-2) 0 0; }
.credit a { color: var(--link); }
.credit a:hover { color: var(--accent); }

.sub {
  margin-top: var(--sp-12);
  padding-top: var(--sp-6);
  border-top: 1px solid var(--border);
  color: var(--fg-subtle); font-size: var(--fs-xs);
}
.sub small { color: inherit; }
</style>
