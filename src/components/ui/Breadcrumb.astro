---
interface Crumb { name: string; href: string; }
interface Props { crumbs: Crumb[]; }
const { crumbs } = Astro.props;
---
<nav aria-label="Breadcrumb" class="crumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1
          ? <a href={c.href}>{c.name}</a>
          : <span aria-current="page">{c.name}</span>}
        {i < crumbs.length - 1 && <span class="sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
.crumb { margin: var(--sp-4) 0 var(--sp-6); font-size: var(--fs-sm); color: var(--fg-muted); }
.crumb ol {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-1);
}
.crumb li { display: inline-flex; align-items: center; gap: var(--sp-1); }
.crumb a {
  color: var(--fg-muted); text-decoration: none;
  padding: var(--sp-1) var(--sp-1);
  border-radius: var(--r-xs);
  transition: var(--transition-colors);
}
.crumb a:hover { color: var(--accent); text-decoration: underline; }
.crumb a:focus-visible { outline: var(--ring); outline-offset: 2px; }
.crumb [aria-current="page"] { color: var(--fg); font-weight: var(--fw-medium); }
.crumb .sep { padding: 0 var(--sp-1); color: var(--fg-subtle); }
</style>
