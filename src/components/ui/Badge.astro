---
/**
 * Badge — compact status / category chip (zero-JS).
 *
 * For jurisdiction tags (US/UK), category eyebrows, "Free", "Updated", counts.
 * Decorative by default; pass a meaningful `aria-label` via ...rest if the chip
 * is the sole carrier of information.
 *
 * Props:
 *   tone     'neutral' (default) | 'accent' | 'brand' | 'success' | 'danger' | 'info'
 *   variant  'soft' (tinted bg — default) | 'solid' (filled) | 'outline'
 *   size     'sm' (default) | 'md'
 *   pill     boolean — fully rounded (default true)
 *   as       tag (default 'span')
 *   class    extra classes
 *
 * Slots: default (label), `icon` (leading glyph).
 */
interface Props {
  tone?: 'neutral' | 'accent' | 'brand' | 'success' | 'danger' | 'info';
  variant?: 'soft' | 'solid' | 'outline';
  size?: 'sm' | 'md';
  pill?: boolean;
  as?: string;
  class?: string;
}
const {
  tone = 'neutral',
  variant = 'soft',
  size = 'sm',
  pill = true,
  as = 'span',
  class: className = '',
  ...rest
} = Astro.props;
const Tag = as as any;
---
<Tag
  class:list={['u-badge', `u-badge--${tone}`, `u-badge--${variant}`, `u-badge--${size}`, pill && 'u-badge--pill', className]}
  {...rest}
>
  <slot name="icon" /><slot />
</Tag>

<style>
.u-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-1);
  font-family: var(--font-body);
  font-weight: var(--fw-semibold);
  line-height: 1;
  white-space: nowrap;
  border: 1px solid transparent;
  border-radius: var(--r-sm);
}
.u-badge--pill { border-radius: var(--r-full); }
.u-badge--sm { font-size: var(--fs-xs); padding: 0.28em 0.62em; letter-spacing: 0.01em; }
.u-badge--md { font-size: var(--fs-sm); padding: 0.34em 0.78em; }

/* ---- soft (tinted) ---- */
.u-badge--soft.u-badge--neutral { background: var(--surface-2); color: var(--fg-muted); }
.u-badge--soft.u-badge--accent  { background: var(--accent-tint); color: var(--accent-strong); }
.u-badge--soft.u-badge--brand   { background: color-mix(in srgb, var(--brand) 12%, transparent); color: var(--brand); }
.u-badge--soft.u-badge--success { background: var(--success-bg); color: var(--success); }
.u-badge--soft.u-badge--danger  { background: var(--danger-bg); color: var(--danger); }
.u-badge--soft.u-badge--info    { background: var(--info-bg); color: var(--info); }

/* ---- solid (filled) ---- */
.u-badge--solid.u-badge--neutral { background: var(--fg-muted); color: var(--bg-elev); }
.u-badge--solid.u-badge--accent  { background: var(--accent); color: var(--accent-fg); }
.u-badge--solid.u-badge--brand   { background: var(--brand); color: var(--brand-fg); }
.u-badge--solid.u-badge--success { background: var(--success); color: var(--bg); }
.u-badge--solid.u-badge--danger  { background: var(--danger); color: var(--bg); }
.u-badge--solid.u-badge--info    { background: var(--info); color: var(--bg); }

/* ---- outline ---- */
.u-badge--outline { background: transparent; }
.u-badge--outline.u-badge--neutral { border-color: var(--border-strong); color: var(--fg-muted); }
.u-badge--outline.u-badge--accent  { border-color: var(--accent-bold); color: var(--accent-strong); }
.u-badge--outline.u-badge--brand   { border-color: var(--brand); color: var(--brand); }
.u-badge--outline.u-badge--success { border-color: var(--success); color: var(--success); }
.u-badge--outline.u-badge--danger  { border-color: var(--danger); color: var(--danger); }
.u-badge--outline.u-badge--info    { border-color: var(--info); color: var(--info); }
</style>
