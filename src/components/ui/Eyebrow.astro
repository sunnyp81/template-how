---
/**
 * Eyebrow — a small uppercase kicker label that sits above a heading to give a
 * section context ("LEGAL TEMPLATES", "STEP 2"). Decorative typographic accent.
 *
 * Props:
 *   tone   'accent' (amber — default) | 'muted' | 'brand'
 *   as     tag (default 'p')
 *   class  extra
 *
 * Slot: default (label text).
 */
interface Props {
  tone?: 'accent' | 'muted' | 'brand';
  as?: string;
  class?: string;
}
const { tone = 'accent', as = 'p', class: className = '', ...rest } = Astro.props;
const Tag = as as any;
---
<Tag class:list={['u-eyebrow', `u-eyebrow--${tone}`, className]} {...rest}>
  <slot />
</Tag>

<style>
.u-eyebrow {
  margin: 0 0 var(--sp-2);
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  font-weight: var(--fw-bold);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wide);
  line-height: var(--lh-snug);
}
.u-eyebrow--accent { color: var(--accent-strong); }
.u-eyebrow--muted { color: var(--fg-subtle); }
.u-eyebrow--brand { color: var(--brand); }
</style>
