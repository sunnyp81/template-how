---
/**
 * FaqList — the on-page FAQ that mirrors FAQPageSchema. Native <details>/<summary>
 * disclosures (zero-JS, keyboard-accessible by default) with a rotating chevron
 * and a comfortable reading measure on the answers. Question text and answers
 * are passed verbatim so the visible copy matches the JSON-LD.
 */
interface QA { q: string; a: string; }
interface Props {
  faq: QA[];
  id?: string;
  class?: string;
}
const { faq, id = 'faq', class: className = '' } = Astro.props;
const headingId = `${id}-h`;
---
<section class:list={['faq', className]} id={id} aria-labelledby={headingId}>
  <h2 id={headingId} class="faq-h">Frequently asked questions</h2>
  <div class="faq-list">
    {faq.map((qa) => (
      <details class="faq-item">
        <summary class="faq-q">
          <span class="faq-q-text">{qa.q}</span>
          <svg class="faq-chev" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="faq-a"><p>{qa.a}</p></div>
      </details>
    ))}
  </div>
</section>

<style>
.faq-h {
  font-family: var(--font-display);
  font-weight: var(--fw-medium);
  font-size: var(--fs-2xl);
  margin: 0 0 var(--sp-6);
}
.faq-list {
  display: grid;
  gap: var(--sp-3);
}
.faq-item {
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  background: var(--bg-elev);
  overflow: hidden;
  transition: border-color var(--dur-fast) var(--ease-standard);
}
.faq-item[open] { border-color: var(--border-strong); }
.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  list-style: none;
  cursor: pointer;
  padding: var(--sp-4) var(--sp-5);
  min-height: 44px;
}
.faq-q::-webkit-details-marker { display: none; }
.faq-q:focus-visible { outline: var(--ring); outline-offset: -2px; border-radius: var(--r-lg); }
.faq-q-text {
  font-family: var(--font-display);
  font-weight: var(--fw-medium);
  font-size: var(--fs-lg);
  line-height: var(--lh-snug);
  color: var(--fg);
}
.faq-chev { flex: none; color: var(--fg-subtle); transition: var(--transition-transform); }
.faq-item[open] .faq-chev { transform: rotate(180deg); }
.faq-a {
  padding: 0 var(--sp-5) var(--sp-5);
  color: var(--fg-muted);
  line-height: var(--lh-body);
  max-width: var(--content-max);
}
.faq-a p { margin: 0; text-wrap: pretty; }
</style>
