---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import HowToSchema from '@/components/schema/HowToSchema.astro';
import FAQPageSchema from '@/components/schema/FAQPageSchema.astro';
import AuthorBox from '@/components/content/AuthorBox.astro';
import SourceList from '@/components/content/SourceList.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Grid from '@/components/ui/Grid.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Callout from '@/components/ui/Callout.astro';
import BuilderCTA from '@/components/seed/BuilderCTA.astro';
import { ALL_JURISDICTIONS, US_STATES, UK_NATIONS, type Jurisdiction } from '@/data/jurisdictions';
import rules from '@/data/legal/bill-of-sale-state-rules.json';

interface Rule {
  code: string;
  notary_required: boolean | null;
  witness_required: boolean | null;
  required_fields: string[];
  vehicle_extra_fields: string[];
  governing_statute: string | null;
  statute_url: string | null;
  vehicle_dmv_form: string | null;
  vehicle_dmv_url: string | null;
  notes: string;
  last_verified: string;
}

export async function getStaticPaths() {
  return ALL_JURISDICTIONS.map((j) => ({
    params: { variant: j.slug },
    props: { jurisdiction: j }
  }));
}

interface Props { jurisdiction: Jurisdiction; }
const { jurisdiction } = Astro.props;
const rule = rules[jurisdiction.code as keyof typeof rules] as Rule;

const isUS = jurisdiction.country === 'us';
const cur = isUS ? '$' : '£';
const peer = isUS ? US_STATES : UK_NATIONS;

// Locale-aware display copy: American spelling for US-state variants, British for UK nations.
// Only display strings vary — never `code`/data values.
const sp = {
  neighbouring: isUS ? 'neighboring' : 'neighbouring',
  notarised: isUS ? 'notarized' : 'notarised',
  notarisation: isUS ? 'notarization' : 'notarisation',
  cheque: isUS ? 'check' : 'cheque',
  // Sentence-case variant where the word opens a step name.
  Notarise: isUS ? 'Notarize' : 'Notarise',
  // Sentence-case noun for use as a heading.
  Notarisation: isUS ? 'Notarization' : 'Notarisation'
};
const dmvAuthority = isUS ? 'DMV' : 'DVLA';
const legalAdvisor = isUS ? 'attorney' : 'solicitor';

// UK transfer authority: DVLA covers GB; Northern Ireland is administered by DVA.
const transferAuthority = isUS
  ? `your local ${jurisdiction.region} DMV`
  : jurisdiction.code === 'uk-nir'
    ? 'the DVA in Northern Ireland'
    : 'the DVLA';
// Generic pointer for the official transfer form/URL, falling back gracefully when
// no jurisdiction-specific form is recorded in the data.
const hasForm = Boolean(rule.vehicle_dmv_form);

// Rotating-window siblings: 5 before + 5 after (wrapping), so every US state appears
// in exactly 10 other US state pages — guarantees ≥3 incoming for all variants.
// UK nations only have 3 peers — just show all of them.
const peerIdx = peer.findIndex((j) => j.code === jurisdiction.code);
const siblings: typeof peer = [];
if (peer.length <= 5) {
  // Small pool (UK nations): show every peer except self
  siblings.push(...peer.filter((j) => j.code !== jurisdiction.code));
} else {
  const windowSize = 5;
  const seen = new Set<string>();
  for (let offset = 1; offset <= windowSize; offset++) {
    const before = peer[(peerIdx - offset + peer.length) % peer.length];
    const after = peer[(peerIdx + offset) % peer.length];
    if (!seen.has(before.code) && before.code !== jurisdiction.code) {
      siblings.push(before);
      seen.add(before.code);
    }
    if (!seen.has(after.code) && after.code !== jurisdiction.code) {
      siblings.push(after);
      seen.add(after.code);
    }
  }
}

const title = `Bill of Sale Template — ${jurisdiction.region} (${jurisdiction.abbreviation})`;
const h1 = `${jurisdiction.region} Bill of Sale Template`;
const lede = `A bill of sale for personal property in ${jurisdiction.region} records the transfer of ownership from seller to buyer. ${jurisdiction.region}'s rules differ from ${sp.neighbouring} jurisdictions in specific, sometimes consequential ways.`;
const updated = new Date(rule.last_verified);

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Legal documents', href: '/legal-document-templates/' },
  { name: 'Bill of Sale', href: '/bill-of-sale/' },
  { name: jurisdiction.region, href: `/bill-of-sale/${jurisdiction.slug}/` }
];

const sources = [
  rule.statute_url ? { title: rule.governing_statute ?? 'Governing statute', url: rule.statute_url, accessed: rule.last_verified } : null,
  rule.vehicle_dmv_url ? { title: rule.vehicle_dmv_form ?? 'Vehicle transfer form', url: rule.vehicle_dmv_url, accessed: rule.last_verified } : null
].filter(Boolean) as Array<{ title: string; url: string; accessed: string }>;

const howTo = {
  name: `How to fill out a ${jurisdiction.region} bill of sale`,
  steps: [
    { name: 'Identify the parties', text: `Write the full legal names and addresses of both seller and buyer in ${jurisdiction.region}.` },
    { name: 'Describe the item', text: `For a vehicle, include ${rule.vehicle_extra_fields.join(', ')}. For other personal property, describe it precisely enough that no other identical item could be substituted.` },
    { name: 'State the price and payment method', text: `Record the agreed price in ${cur} and how it was paid (cash, bank transfer, cashier's ${sp.cheque}).` },
    rule.notary_required === true
      ? { name: `${sp.Notarise} the document`, text: `${jurisdiction.region} requires the bill of sale to be ${sp.notarised} before it is legally effective for vehicle transfers.` }
      : { name: 'Sign and date', text: `Both parties sign and date. ${jurisdiction.region} does not require a notary for personal property bills of sale.` },
    rule.witness_required === true
      ? { name: 'Sign in front of witnesses', text: `${jurisdiction.region} requires the bill of sale to be signed in the presence of at least two witnesses for vehicle transfers.` }
      : null
  ].filter(Boolean) as Array<{ name: string; text: string }>
};

const faq = [
  {
    q: `Is a notary required for a ${jurisdiction.region} bill of sale?`,
    a: rule.notary_required === true
      ? `Yes. ${jurisdiction.region} requires bills of sale for vehicle transfers to be ${sp.notarised}. Find a notary at a bank, library, UPS Store, or law office.`
      : rule.notary_required === false
        ? `No. ${jurisdiction.region} does not require a notary for a bill of sale, although having one ${sp.notarised} does not hurt and may speed up dispute resolution.`
        : `${jurisdiction.region}'s requirements vary by item type. For vehicles, check the local ${isUS ? 'DMV' : 'DVLA / DVA'} guidance.`
  },
  {
    q: `What form does ${jurisdiction.region} use for vehicle transfer?`,
    a: rule.vehicle_dmv_form
      ? `${jurisdiction.region} ${isUS ? 'uses' : 'accepts'} ${rule.vehicle_dmv_form}${rule.vehicle_dmv_url ? ` (available from the official ${isUS ? 'DMV' : 'DVLA'} site)` : ''}.`
      : `${jurisdiction.region} does not specify a single official form for private vehicle transfer; the bill of sale plus the title or registration document is usually sufficient.`
  },
  {
    q: `Can I use a generic bill of sale in ${jurisdiction.region}?`,
    a: `A generic bill of sale is valid in ${jurisdiction.region} as long as it includes the parties, the item, the price, the date, and signatures. ${rule.notary_required === true ? `It must also be ${sp.notarised} for vehicle transfers.` : ''} Using the official ${jurisdiction.region}-specific form removes any ambiguity.`
  },
  {
    q: `What is the governing law in ${jurisdiction.region}?`,
    a: rule.governing_statute
      ? `${rule.governing_statute} governs the form and effect of bills of sale in ${jurisdiction.region}.`
      : isUS
        ? `Article 2 of the Uniform Commercial Code, as adopted by ${jurisdiction.region}, applies to most personal property sales.`
        : `The Sale of Goods Act 1979 (as amended) applies UK-wide, including ${jurisdiction.region}.`
  },
  {
    q: `What if the buyer or seller lives in another ${isUS ? 'state' : 'nation'}?`,
    a: `For vehicle transfers, the bill of sale should follow the law of the state ${isUS ? 'where the vehicle will be registered' : 'where the buyer will register the vehicle'}. The buyer registers in their home ${isUS ? 'state' : 'nation'}.`
  },
  {
    q: `Do I need a witness for a ${jurisdiction.region} bill of sale?`,
    a: rule.witness_required === true
      ? `Yes — ${jurisdiction.region} requires the bill of sale to be signed in the presence of at least two witnesses for vehicle transfers.`
      : `No. Witnesses are not required by ${jurisdiction.region} law for a private bill of sale, although either party can choose to have one for evidentiary value.`
  },
  {
    q: `How long should I keep the bill of sale?`,
    a: `Both parties should retain a signed original. In ${jurisdiction.region}, the practical retention period is at least the statutory limitation period for breach of contract (${isUS ? 'typically 4-6 years for written contracts' : '6 years under the UK Limitation Act 1980'}), plus the period during which any tax liability arising from the sale could be re-assessed.`
  },
  {
    q: `What if there is a dispute later?`,
    a: `A signed bill of sale is the primary evidence of a private sale in ${jurisdiction.region}. If a dispute arises, the small claims court (${isUS ? `${jurisdiction.region}'s civil court` : 'County Court / Sheriff Court'}) is usually the first venue. Photographs of the item at handover and the original bill of sale are the most useful evidence.`
  }
];
---
<BaseLayout
  title={title}
  description={lede}
  modifiedTime={updated}
  article={{ headline: h1, description: lede }}>
  <BreadcrumbSchema slot="head" crumbs={crumbs} />
  <HowToSchema slot="head" name={howTo.name} steps={howTo.steps} />
  <FAQPageSchema slot="head" faq={faq} />

  <Container size="page">
    <Breadcrumb crumbs={crumbs} />
  </Container>

  {/* ── Variant header + CTA into the builder ──────────────────── */}
  <Section tone="default" space="sm" container="page" aria-labelledby="variant-h1">
    <div class="bos-hero">
      <Eyebrow tone="accent">
        Legal documents · Bill of sale · {jurisdiction.region}
      </Eyebrow>
      <h1 id="variant-h1">{h1}</h1>
      <p class="bos-hero__lede">{lede}</p>
      <div class="bos-hero__badges">
        <Badge tone="brand" variant="soft">{isUS ? 'US' : 'UK'}</Badge>
        <Badge tone="neutral" variant="outline">{jurisdiction.abbreviation}</Badge>
        {rule.notary_required === true && <Badge tone="accent" variant="soft">Notary required</Badge>}
        {rule.witness_required === true && <Badge tone="accent" variant="soft">Witnesses required</Badge>}
      </div>
    </div>
    <BuilderCTA
      noun="bill of sale"
      target="/bill-of-sale/#builder"
      audience={[isUS ? 'us' : 'uk']}
      class="bos-hero__cta" />
    <p class="bos-hero__browse">
      <Button href="/legal-document-templates/" variant="ghost" size="sm">
        Browse all legal templates
        <span slot="icon-end" aria-hidden="true">→</span>
      </Button>
    </p>
  </Section>

  {/* ── Requirements at a glance ───────────────────────────────── */}
  <Section tone="surface" space="default" container="content" aria-labelledby="rules-h">
    <Eyebrow tone="brand">At a glance</Eyebrow>
    <h2 id="rules-h" class="bos-h2">{jurisdiction.region} requirements</h2>
    <Card variant="raised" padding="lg" class="bos-rule">
      <dl class="bos-rule__list">
        <div><dt>Notary required</dt><dd>{rule.notary_required === true ? 'Yes' : rule.notary_required === false ? 'No' : 'Varies'}</dd></div>
        <div><dt>Witnesses required</dt><dd>{rule.witness_required === true ? 'Yes' : rule.witness_required === false ? 'No' : 'Varies'}</dd></div>
        <div><dt>Governing statute</dt><dd>{rule.statute_url ? <a href={rule.statute_url} rel="noopener">{rule.governing_statute}</a> : (rule.governing_statute ?? '—')}</dd></div>
        <div><dt>Vehicle transfer form</dt><dd>{rule.vehicle_dmv_url ? <a href={rule.vehicle_dmv_url} rel="noopener">{rule.vehicle_dmv_form}</a> : (rule.vehicle_dmv_form ?? '—')}</dd></div>
        <div><dt>Last verified</dt><dd><time datetime={rule.last_verified}>{rule.last_verified}</time></dd></div>
      </dl>
      {rule.notes ? <p class="bos-rule__notes">{rule.notes}</p> : null}
    </Card>
    <Callout tone="warning" title="This is not legal advice">
      <p>Templates and jurisdiction notes here are for general information only. Confirm current requirements with the relevant {dmvAuthority} or a qualified {legalAdvisor} before relying on them.</p>
    </Callout>
  </Section>

  {/* ── Article body ───────────────────────────────────────────── */}
  <Section tone="default" space="default" container="content" aria-labelledby="article-h">
    <div class="bos-article">
      <h2 id="article-h">What a bill of sale does in {jurisdiction.region}</h2>
      <p>A bill of sale records the transfer of ownership of personal property — a car, a boat, a piece of equipment, livestock, sometimes a firearm — from one private party to another. In {jurisdiction.region}, the document acts as both a receipt for the buyer and a release of liability for the seller. Once signed, ownership has changed; the seller is no longer the legal owner and is no longer liable for what the buyer subsequently does with the item.</p>

      <p>{jurisdiction.region}'s position is that {rule.governing_statute ? `${rule.governing_statute} governs the form and effect of these transfers.` : `general principles of contract law govern these transfers.`} The bill of sale itself does not transfer title to a vehicle on its own — that requires the {isUS ? `${jurisdiction.region} DMV` : 'DVLA (or DVA in Northern Ireland)'} to record the change of ownership using the {rule.vehicle_dmv_form ? rule.vehicle_dmv_form : 'appropriate transfer form'}.</p>

      <h2>What to include</h2>
      <ul>
        {rule.required_fields.map((f) => <li>{f.replace(/_/g, ' ')}</li>)}
      </ul>
      <p>For a vehicle, also include: {rule.vehicle_extra_fields.map((f) => f.replace(/_/g, ' ')).join(', ')}.</p>

      <h2>How {jurisdiction.region} differs</h2>
      <p>{rule.notes}{rule.notary_required === true ? ` That makes ${jurisdiction.region} stricter than the majority of US states, where ${sp.notarisation} is not required for a private vehicle sale.` : ''}{rule.witness_required === true ? ` ${jurisdiction.region} also requires witnesses, which is unusual.` : ''} For comparison, {isUS ? `most US states do not require ${sp.notarisation}` : `other UK nations follow Sale of Goods Act 1979 with no ${sp.notarisation} requirement`}, although having a notary or witness adds evidentiary weight if a dispute later arises.</p>

      <Callout tone="tip" title="Expert tip">
        <p>Take a photograph of the item, the keys, and both parties at the moment of handover. {jurisdiction.region}'s small claims courts give significant weight to contemporaneous photographic evidence in dispute over the condition of the item at sale. The bill of sale records the transaction; the photograph records the state of the goods.</p>
      </Callout>

      <h2>Title transfer &amp; registration in {jurisdiction.region}</h2>
      <p>A bill of sale documents the deal, but for a vehicle it is only one step in changing the registered owner. In {jurisdiction.region}, the general process runs in the same order: the seller signs over the {isUS ? 'certificate of title' : 'logbook (V5C)'}, both parties complete and sign the bill of sale{hasForm ? <>{' '}(and {rule.vehicle_dmv_url ? <a href={rule.vehicle_dmv_url} rel="noopener">{rule.vehicle_dmv_form}</a> : rule.vehicle_dmv_form}, where {jurisdiction.region} provides an official form)</> : null}, and then the <strong>buyer</strong> submits the transfer and registers the vehicle.</p>
      <p>{isUS
        ? <>The buyer takes the assigned title and bill of sale to {transferAuthority}, applies for a new title in their own name, registers the vehicle, and pays the applicable titling and registration fees plus any tax due. Most states set a statutory window — often around a month — within which the buyer must complete the transfer, so file promptly to avoid late penalties. {rule.vehicle_dmv_url ? <>Confirm the current {jurisdiction.region} fees, deadlines, and form versions on the <a href={rule.vehicle_dmv_url} rel="noopener">official {dmvAuthority} page</a> before you go.</> : <>Confirm the current {jurisdiction.region} fees and deadlines with your local {dmvAuthority} before you go.</>}</>
        : <>The seller and buyer notify {transferAuthority} of the change of keeper — usually online — using the {hasForm ? <>{rule.vehicle_dmv_url ? <a href={rule.vehicle_dmv_url} rel="noopener">{rule.vehicle_dmv_form}</a> : rule.vehicle_dmv_form} new keeper supplement</> : 'V5C new keeper supplement'}. The buyer keeps the supplement until the updated registration document arrives, taxes the vehicle before driving it, and arranges insurance. {rule.vehicle_dmv_url ? <>Use the <a href={rule.vehicle_dmv_url} rel="noopener">official {jurisdiction.region} guidance</a> to complete the transfer.</> : null}</>}</p>

      <h2>{sp.Notarisation} &amp; witnesses</h2>
      <p>{rule.notary_required === true
        ? <>{jurisdiction.region} requires the {rule.witness_required === true ? 'bill of sale or vehicle title' : 'vehicle title or bill of sale'} to be {sp.notarised} for a vehicle transfer. In practice that means the seller signs in front of a notary public, who verifies identity and seals the document. In the US you can usually get a document {sp.notarised} at a bank, credit union, law office, UPS Store, or many public libraries, often for a small fee. Building this step into your handover keeps the transfer valid the first time it is presented to {transferAuthority}.</>
        : rule.notary_required === false
          ? <>{jurisdiction.region} does <strong>not</strong> require the bill of sale to be {sp.notarised} for a private {isUS ? 'vehicle' : 'used-vehicle'} sale. {isUS ? <>You can still choose to have it {sp.notarised} at a bank, UPS Store, or law office — it is never wrong, and a notary's seal adds evidentiary weight if the transaction is ever questioned.</> : <>A private sale in {jurisdiction.region} generally needs neither a notary nor witnesses; the parties simply sign and date, and the change of keeper is recorded with {transferAuthority}. Even so, both signing in front of an independent witness adds evidentiary weight if the sale is later disputed.</>}</>
          : <>Whether {jurisdiction.region} requires {sp.notarisation} can vary by item type and circumstance, so confirm the current requirement with {transferAuthority} or a qualified {legalAdvisor}. A {sp.notarised} signature is never wrong and adds evidentiary weight if the sale is later questioned.</>}{rule.witness_required === true ? <> {jurisdiction.region} additionally requires the document to be signed in front of at least two witnesses, which is unusual — arrange this at the same sitting as the signing.</> : null}</p>

      <h2>Sales &amp; use tax</h2>
      <p>{isUS
        ? <>In the US, the buyer — not the seller — normally pays state and local <strong>use tax</strong> when they title and register the vehicle, and it is typically calculated on the purchase price. That is exactly why the price written on the bill of sale matters: {transferAuthority} may use the stated figure (or a fair-market value) to assess what is owed. Record the real, agreed price honestly. {rule.notes && /no (state )?sales tax|no sales tax/i.test(rule.notes) ? <>As reflected in {jurisdiction.region}'s own guidance above, this jurisdiction is among those without a general sales tax on the purchase, but registration and titling fees can still apply.</> : <>Exact rates, exemptions, and any local add-ons vary{rule.vehicle_dmv_url ? <>, so confirm them on the <a href={rule.vehicle_dmv_url} rel="noopener">official {jurisdiction.region} {dmvAuthority} page</a> before registering</> : ' with your local DMV before registering'}.</>}</>
        : <>For a private used-vehicle sale in {jurisdiction.region}, <strong>VAT generally does not apply</strong> — VAT is a concern for VAT-registered traders, not ordinary private sellers. The buyer's main running cost to budget for is vehicle tax (road tax), which must be set up before the vehicle is driven. Still record the true sale price on the bill of sale: it is your proof of what was paid if the transaction is ever questioned.</>}</p>

      <h2>Keep a copy &amp; dispute evidence</h2>
      <p>Both the buyer and the seller should keep a signed copy of the bill of sale — ideally each retaining an original, or a clear scan or photograph of the fully signed document. For the seller it proves the date ownership and liability passed; for the buyer it proves what was paid and on what terms. Store it together with any handover photographs and a note of the {isUS ? 'odometer' : 'mileage'} reading at sale. If a dispute arises later, this contemporaneous paperwork is the most persuasive evidence either party can bring to {isUS ? `${jurisdiction.region}'s civil or small claims court` : 'the County Court or Sheriff Court'}.</p>
    </div>
  </Section>

  {/* ── Sibling jurisdictions ──────────────────────────────────── */}
  <Section tone="sunken" space="default" container="page" aria-labelledby="siblings-h">
    <header class="bos-siblings__head">
      <Eyebrow tone="accent">More jurisdictions</Eyebrow>
      <h2 id="siblings-h">Bills of sale in other {isUS ? 'US states' : 'UK nations'}</h2>
    </header>
    <Grid as="ul" min="220px" gap="md">
      {siblings.map((s) => (
        <li>
          <Card href={`/bill-of-sale/${s.slug}/`} variant="default" padding="sm" class="bos-sib">
            <span class="bos-sib__region">{s.region}</span>
            <span class="bos-sib__abbr">{s.abbreviation}</span>
          </Card>
        </li>
      ))}
    </Grid>
    <p class="bos-siblings__back">
      <Button href="/bill-of-sale/" variant="ghost" size="sm">
        Back to all bill-of-sale jurisdictions
        <span slot="icon-end" aria-hidden="true">→</span>
      </Button>
    </p>
  </Section>

  <Section tone="default" space="default" container="content">
    {sources.length > 0 ? <SourceList sources={sources} /> : null}
    <AuthorBox />
  </Section>
</BaseLayout>

<style>
.bos-hero { max-width: var(--measure-wide); }
.bos-hero h1 {
  font-size: var(--fs-4xl);
  line-height: var(--lh-tight);
  letter-spacing: var(--tracking-tight);
  margin: 0 0 var(--sp-4);
  text-wrap: balance;
}
.bos-hero__lede {
  font-size: var(--fs-lg); line-height: var(--lh-body);
  color: var(--fg-muted); max-width: var(--content-max); margin: 0;
}
.bos-hero__badges { display: flex; flex-wrap: wrap; gap: var(--sp-2); margin-top: var(--sp-5); }
.bos-hero + :global(.builder-cta) { margin-top: var(--sp-6); }
.bos-hero__browse { margin: var(--sp-4) 0 0; }

.bos-h2, .bos-article h2, .bos-siblings__head h2 {
  font-size: var(--fs-2xl); line-height: var(--lh-tight); text-wrap: balance;
}
.bos-h2 { margin: 0 0 var(--sp-4); }

.bos-rule__list {
  display: grid; gap: var(--sp-3) var(--sp-8); margin: 0;
}
@media (min-width: 480px) { .bos-rule__list { grid-template-columns: 1fr 1fr; } }
.bos-rule__list > div {
  display: grid; grid-template-columns: max-content 1fr; gap: var(--sp-2) var(--sp-4);
  align-items: baseline; padding-bottom: var(--sp-3); border-bottom: 1px solid var(--border);
}
.bos-rule__list dt { font-weight: var(--fw-semibold); color: var(--fg-muted); font-size: var(--fs-sm); }
.bos-rule__list dd { margin: 0; font-size: var(--fs-sm); }
.bos-rule__notes { margin: var(--sp-4) 0 0; font-size: var(--fs-sm); font-style: italic; color: var(--fg-muted); }

.bos-article { color: var(--fg); line-height: var(--lh-body); }
.bos-article > * + * { margin-top: var(--sp-4); }
.bos-article h2 { margin-top: var(--sp-10); }
.bos-article h2:first-child { margin-top: 0; }
.bos-article h2 + * { margin-top: var(--sp-3); }
.bos-article ul { padding-left: var(--sp-6); }
.bos-article li + li { margin-top: var(--sp-2); }

.bos-siblings__head { margin-bottom: var(--sp-6); }
.bos-sib :global(.u-card__body) {
  flex-direction: row; align-items: center; justify-content: space-between; gap: var(--sp-2);
}
.bos-sib__region { font-weight: var(--fw-medium); font-size: var(--fs-sm); }
.bos-sib__abbr { color: var(--fg-subtle); font-size: var(--fs-xs); font-weight: var(--fw-semibold); }
.bos-siblings__back { margin: var(--sp-6) 0 0; }
</style>
